{
  "expo": {
    "name": "Stud-Stop",
    "slug": "stud-stop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "studstop",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0C1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.studstop.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Upload profile avatar",
        "NSPhotoLibraryUsageDescription": "Upload study materials"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E0C1A"
      },
      "package": "com.studstop.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-sensors",
      "expo-document-picker",
      "expo-image-picker",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
